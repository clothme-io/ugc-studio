# API
PORT=4000
API_PUBLIC_URL=http://localhost:4000
DATABASE_URL=postgresql://ugc:ugc@localhost:5433/ugc_studio
REDIS_URL=redis://localhost:6380
API_SECRET=change-me-in-production
UPLOAD_DIR=./uploads

# LLM for analyze + remix — OpenRouter (preferred) or direct OpenAI
# Auto-detects: OpenRouter if OPENROUTER_API_KEY is set, else OpenAI
AI_PROVIDER=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_NAME=UGC Studio
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# AI UGC (HeyGen — required for AI UGC generation)
HEYGEN_API_KEY=

# File storage — local disk by default; uploads go to Bunny.net when configured
BUNNY_STORAGE_ZONE=
BUNNY_STORAGE_API_KEY=
BUNNY_STORAGE_REGION=storage.bunnycdn.com
BUNNY_CDN_HOSTNAME=

# Optional: video discovery via Apify (not used in Stage 2 MVP)
APIFY_API_TOKEN=

# Web (3100 avoids conflict with other ClothME apps on 3000)
WEB_PORT=3100
WEB_ORIGIN=http://localhost:3100
NEXT_PUBLIC_API_URL=http://localhost:4000

# UI mock mode (default: true). Set to false when API + DB + LLM key are ready.
NEXT_PUBLIC_USE_MOCK=true
